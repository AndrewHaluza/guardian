{
  "name": "guardian",
  "version": "1.0.0",
  "description": "Code Guardian - high-performance security scanning backend service",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:watch": "tsc -p tsconfig.json --watch",
    "test": "mocha --require ts-node/register --timeout 30000 'test/**/*.ts' --grep '^(?!.*E2E)'",
    "test:e2e": "RUN_E2E=1 mocha --require ts-node/register --timeout 60000 test/stress/memory.stress.test.ts",
    "test:all": "npm run build && npm test && npm run test:e2e",
    "start": "node dist/index.js",
    "start:with-limit": "NODE_OPTIONS=\"--max-old-space-size=256\" npm start"
  },
  "dependencies": {
    "@types/node": "^20.x",
    "@types/stream-chain": "^2.1.0",
    "@types/stream-json": "^1.7.8",
    "dotenv": "^16.4.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.0",
    "helmet": "^7.1.0",
    "mongodb": "^6",
    "stream-json": "^1.8.0",
    "typescript": "^5.x",
    "uuid": "^9.0.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/chai": "^4.3.0",
    "@types/express": "^5.0.6",
    "@types/mocha": "^10.0.0",
    "@types/sinon": "^21.0.0",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "chai": "^4.3.0",
    "mocha": "^11.7.5",
    "mongodb-memory-server": "^11.0.1",
    "sinon": "^17.0.0",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.0"
  }
}
