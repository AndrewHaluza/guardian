# Guardian Configuration Example
# Copy this file to .env and adjust values as needed

# ==============================================================================
# MongoDB Configuration
# ==============================================================================
# MongoDB connection URI for Guardian database
# Default: mongodb://localhost:27017/guardian
GUARDIAN_MONGODB_URI=mongodb://localhost:27017/guardian

# ==============================================================================
# Server Configuration
# ==============================================================================
# HTTP server port
# Default: 3000
GUARDIAN_PORT=3000

# ==============================================================================
# Scan Limits
# ==============================================================================
# Maximum number of concurrent scans allowed (worker pool size)
# Default: 3
# Note: Pre-warmed thread pool (~6MB overhead for 3 threads) + per-scan ~70-140 MB heap
#       Total: ~180 MB peak heap under 256MB pod constraint (comfortable headroom)
# Warning: Pool is unbounded by default. Limit via rate limiting to prevent queue growth.
GUARDIAN_MAX_CONCURRENT_SCANS=3

# Minimum free disk space in MB before running scans
# Default: 512 (MB)
# Scans will not start if less than this much free space is available
GUARDIAN_MIN_FREE_DISK_MB=512

# Maximum number of findings to report per scan
# Default: 500
# Scans abort when this many filtered findings (based on min severity) are reached
GUARDIAN_MAX_FINDINGS=500

# Minimum severity level to report in scan results
# Valid values: CRITICAL, HIGH, MEDIUM, LOW, UNKNOWN
# Default: CRITICAL
# Severity ranking: CRITICAL(4) > HIGH(3) > MEDIUM(2) > LOW(1) > UNKNOWN(0)
# Only vulnerabilities >= minSeverity are reported (filtered server-side)
# Examples:
#   CRITICAL      = Report only CRITICAL vulnerabilities
#   HIGH          = Report CRITICAL and HIGH vulnerabilities
#   MEDIUM        = Report CRITICAL, HIGH, and MEDIUM vulnerabilities
#   LOW           = Report CRITICAL, HIGH, MEDIUM, and LOW vulnerabilities
#   UNKNOWN       = Report all vulnerabilities including unmatched packages
# Note: UNKNOWN severity includes vulnerabilities without a known severity mapping
#       (e.g., unmatched package versions, malformed entries in Trivy output)
GUARDIAN_MIN_SEVERITY=CRITICAL

# ==============================================================================
# Timeout Configuration (in milliseconds)
# ==============================================================================
# Trivy filesystem scan timeout
# Default: 300000 (5 minutes)
GUARDIAN_TRIVY_TIMEOUT=300000

# Git repository clone timeout
# Default: 120000 (2 minutes)
GUARDIAN_GIT_TIMEOUT=120000

# ==============================================================================
# Rate Limiting Configuration (requests per minute per IP)
# ==============================================================================
# Maximum requests to POST /api/scan per minute
# Default: 10
GUARDIAN_RATE_LIMIT_POST_SCAN=10

# Maximum requests to GET /api/scan/:scanId per minute
# Default: 100
GUARDIAN_RATE_LIMIT_GET_SCAN=100

# ==============================================================================
# Logging Configuration
# ==============================================================================
# Log level: debug, info, warn, error
# Default: info
LOG_LEVEL=info

# Log format: json or text
# - json: Structured JSON output for production (parseable by log aggregation)
# - text: Human-readable colored output for development
# Default: json in production, text otherwise
LOG_FORMAT=text

# ==============================================================================
# Environment
# ==============================================================================
# Node environment: development, production, test
# Default: development
# Note: production automatically enables JSON logging
NODE_ENV=development

# ==============================================================================
# Production Deployment Example
# ==============================================================================
# For a production K8s pod with 256MB memory limit:
#
# GUARDIAN_MONGODB_URI=mongodb://mongodb-service:27017/guardian
# GUARDIAN_PORT=3000
# GUARDIAN_MAX_CONCURRENT_SCANS=3
# GUARDIAN_MIN_SEVERITY=HIGH
# GUARDIAN_TRIVY_TIMEOUT=300000
# GUARDIAN_GIT_TIMEOUT=120000
# LOG_LEVEL=info
# LOG_FORMAT=json
# NODE_ENV=production
